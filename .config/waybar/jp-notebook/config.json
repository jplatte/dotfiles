{
    "layer": "top",
    "modules-left": [
        "niri/workspaces"
    ],
    "modules-center": [],
    "modules-right": [
        "custom/pacman",
        "custom/battery",
        "custom/df-root",
        "custom/df-home",
        "custom/wifi",
        "pulseaudio",
        "custom/mpris-volume",
        "clock#date",
        "clock#clock"
    ],
    "niri/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "browser": "¯Çç",
            "chat": "´éå",
            "email": "´âá"
        }
    },
    "custom/pacman": {
        "format": "´åç {0}",
        "exec": "~/.config/waybar/modules/pacman.sh",
        "interval": "once",
        "signal": 7,
        "on-click": "niri msg action spawn -- alacritty -e bash -c 'paru -Syu; pkill -RTMIN+7 waybar; read'",
        "tooltip": false
    },
    "custom/battery": {
        "exec": "~/.config/waybar/modules/battery.sh BAT1",
        "return-type": "json",
        "interval": 15,
        "signal": 2,
        "format": "{icon} {0}",
        "format-icons": [
            "´ëä",
            "´ëâ",
            "´ëé",
            "´ëü",
            "´ëÇ"
        ],
        "tooltip": false
    },
    "custom/df-root": {
        "exec": "~/.config/waybar/modules/df.sh /",
        "interval": 60,
        "format": "<span color='#888'>´éá /</span> {}",
        "tooltip": false
    },
    "custom/df-home": {
        "exec": "~/.config/waybar/modules/df.sh /home/jplatte",
        "interval": 60,
        "format": "<span color='#888'>´éá ´è¢</span> {}",
        "tooltip": false
    },
    "custom/wifi": {
        "exec": "~/.config/waybar/modules/wifi.sh wlp1s0",
        "return-type": "json",
        "interval": "once",
        "signal": 1,
        "format": "{}",
        "on-click": "niri msg action spawn -- alacritty -e nmtui",
        "tooltip": false
    },
    "pulseaudio": {
        "format": "<span color='#888'>{icon}</span> {volume}ÔÇë%",
        "format-bluetooth": "<span color='#888'>{icon} ´èö</span> {volume}ÔÇë%",
        "format-muted": "<span color='#888'>´Ü®</span>",
        "format-icons": {
            "headphones": "´ÇÑ",
            "handsfree": "´ûÉ",
            "headset": "´ûÉ",
            "phone": "´éò",
            "portable": "´éò",
            "car": "´å╣",
            "default": [
                "´Çğ",
                "´Ç¿"
            ]
        },
        "on-click": "pwvucontrol",
        "on-scroll-up": "pamixer -i 5",
        "on-scroll-down": "pamixer -d 5",
        "tooltip": false
    },
    "custom/mpris-volume": {
        "exec": "playerctl volume | awk '{ printf \"%.f\", $1 * 100 }'",
        "interval": 60,
        "signal": 10,
        "format": "<span color='#888'>´Çü</span> {}ÔÇë%",
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl stop",
        "on-scroll-up": "playerctl volume 0.05+; pkill -SIGRTMIN+10 waybar",
        "on-scroll-down": "playerctl volume 0.05-; pkill -SIGRTMIN+10 waybar",
        "tooltip": false
    },
    "clock#date": {
        "format": "<span color='#888'>´ü│</span> {:%d.%m.}",
        "tooltip": false
    },
    "clock#clock": {
        "format": "<span color='#888'>´Çù</span> {:%HÔêÂ%M}",
        "tooltip": false
    }
}
